# Cấu hình — Copy file này thành .env và điền thông tin
# cp .env.example .env

# === Vast.ai ===
VASTAI_API_KEY=your_api_key_here

# === Model ===
VLLM_MODEL=charaf/gemma4-31b-claude-opus-abliterated
VLLM_ARGS=--max-model-len 8192 --gpu-memory-utilization 0.95

# === GPU preference (theo thứ tự ưu tiên) ===
GPU_PREFER=RTX 4090
GPU_MIN_VRAM=24
GPU_MAX_PRICE=0.50

# === Instance ===
INSTANCE_TYPE=on-demand
DISK_SIZE=50
MIN_UPLOAD_SPEED=200

# === HuggingFace (cho gated models, optional) ===
# HF_TOKEN=hf_xxxxx

# === Budget ===
DAILY_BUDGET_LIMIT=5.00
