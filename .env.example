# Cấu hình — Copy file này thành .env và điền thông tin
# cp .env.example .env

# === Vast.ai ===
VASTAI_API_KEY=your_api_key_here

# === Model ===
VLLM_MODEL=charaf/gemma4-31b-claude-opus-abliterated
VLLM_ARGS=--max-model-len 8192 --gpu-memory-utilization 0.95

# === GPU preference ===
# GPU_PREFER không còn bắt buộc — script tự tìm TẤT CẢ GPU compatible
# Chỉ set nếu muốn giới hạn search 1 loại GPU cụ thể
# GPU_PREFER=RTX 4090
GPU_MIN_VRAM=24
GPU_MAX_PRICE=0.60

# === Instance ===
INSTANCE_TYPE=on-demand
DISK_SIZE=50
MIN_UPLOAD_SPEED=200

# === HuggingFace (cho gated models, optional) ===
# HF_TOKEN=hf_xxxxx

# === Budget ===
DAILY_BUDGET_LIMIT=5.00

# === Quantization Notes ===
# GGUF: model tự load từ HuggingFace, không cần thêm arg
# NVFP4: CẦN model đã pre-quantize bằng NVIDIA ModelOpt
#   Nếu có NVFP4 checkpoint: VLLM_ARGS=... --quantization modelopt
#   Model charaf/gemma4-31b... hiện CHƯA CÓ NVFP4 checkpoint
